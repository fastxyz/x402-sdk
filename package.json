{
  "name": "x402-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "x402 HTTP Payment Protocol SDK - Client, Server, and Facilitator",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "rm -rf packages/*/dist",
    "pack:dry-run": "node ./scripts/pack-dry-run.mjs",
    "pack:smoke": "node ./scripts/pack-smoke.mjs",
    "release:verify-tag": "node ./scripts/verify-tag.mjs"
  },
  "keywords": [
    "x402",
    "http",
    "payment",
    "402",
    "fast",
    "evm",
    "sdk"
  ],
  "author": "Fast.xyz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fastxyz/x402-sdk"
  },
  "engines": {
    "node": ">=20"
  }
}
