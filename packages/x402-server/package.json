    "test": "npm run build && node --test dist/__tests__/*.test.js"
  },
  "keywords": [
    "x402",
    "payments",
    "http-402",
    "server",
    "middleware"
  ],
  "author": "Fast.xyz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fastxyz/x402-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/fastxyz/x402-sdk/issues"
  },
  "homepage": "https://github.com/fastxyz/x402-sdk#readme",
  "dependencies": {
    "@fastxyz/allset-sdk": "^0.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
