{
  "name": "@fastxyz/x402-client",
  "version": "0.1.3",
  "description": "Client SDK for x402 HTTP payment protocol - sign and pay for 402-protected content",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepack": "npm run build",
    "test": "npm run build && node --test dist/__tests__/*.test.js",
    "test:watch": "tsc --watch & node --test --watch dist/__tests__/*.test.js"
  },
  "keywords": [
    "x402",
    "http",
    "payment",
    "402",
    "fast",
    "evm",
    "eip-3009",
    "crypto"
  ],
  "author": "Fast.xyz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fastxyz/x402-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/fastxyz/x402-sdk/issues"
  },
  "homepage": "https://github.com/fastxyz/x402-sdk#readme",
  "dependencies": {
    "@fastxyz/allset-sdk": "^0.1.8",
    "@fastxyz/sdk": "^0.2.5",
    "@mysten/bcs": "^2.0.2",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0",
    "bech32": "^2.0.0",
    "viem": "^2.46.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
